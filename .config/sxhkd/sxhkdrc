### Tools ###
# Rofi
super + r
    rofi -show drun
# Show windows
alt + Tab
    rofi -show window
# Show commands
super + F2
    rofi -show run
# Show ssh
super + F3
    rofi -show ssh
# Rofi beats
XF86Tools
    alacritty --title rofi-beats -e ./.scripts/rofi-beats
# Clipboard history
super + c
    rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'
# Show emojis
super + slash
   rofi -show emoji

# Screenshot
Print
    flameshot gui
# Escanear
super + Print
    simple-scan

# Mail
XF86Mail
   thunderbird

# Htop
control + shift + Escape
    alacritty -e htop

# Volume control
super + shift + v
    pavucontrol
super + control + shift + v
    alacritty -e pulsemixer

# Help
super + question
    /home/tony/.scripts/help-keybindings

# Kill
control + alt + x
    xkill

### Music player ###
XF86AudioPlay
    playerctl play-pause
XF86AudioStop
    playerctl stop
XF86AudioPrev
    playerctl previous
XF86AudioNext
    playerctl next
XF86AudioLowerVolume
    playerctl volume .05-
XF86AudioRaiseVolume
    playerctl volume .05+
XF86AudioMute
    playerctl volume 1-

